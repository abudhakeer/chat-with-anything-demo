{
  "name": "chat-with-anything",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "node scripts/check-node.mjs && wrangler dev --config wrangler.local.jsonc",
    "build": "vite build",
    "build:check": "tsc --noEmit && vite build",
    "deploy": "pnpm build && wrangler deploy --config wrangler.jsonc",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "d1:migrate:local": "wrangler d1 migrations apply chat-with-anything --local --config wrangler.local.jsonc",
    "seed:samples": "node scripts/seed-samples.mjs",
    "seed:samples:local": "node scripts/seed-samples.mjs --local",
    "setup:builds": "node scripts/setup-workers-builds.mjs"
  },
  "dependencies": {
    "hono": "^4.7.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250702.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.22.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
